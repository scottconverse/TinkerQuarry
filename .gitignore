# Python
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.venv/
.venv-cq*/
venv/

# Node / build
node_modules/
dist/
.jest-cache/
**/.jest-cache/
# jest.formatter.config.cjs writes its own cache dir, which the pattern above does not match.
.jest-cache-formatter/
**/.jest-cache-formatter/
coverage/
**/coverage/

# Runtime artifacts
output/
*.gcode.3mf
*.stl
*.3mf

# OS / editor
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# Keep the vendored frontend runtime (needed to run offline) — do NOT ignore frontend/vendor
**/node_modules/
apps/*/dist/
packages/*/dist/
*.log
*.exe
*.msi
gate-tinkerquarry-*/artifacts/
.vite/
.wrangler-functions-build/
**/.wrangler-functions-build/
# `pnpm share:dev` persists local KV/R2/Durable Object state here — real share records,
# including their delete-token hashes. Never commit it. (The pattern above does not match it.)
.wrangler/
**/.wrangler/
playwright-report/
test-results/
.fablize/
