{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for all local TinkerQuarry windows",
  "windows": ["*"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-destroy",
    "core:window:allow-set-title",
    "opener:default",
    "dialog:default",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-write-file",
    "fs:allow-exists",
    "fs:allow-read-dir",
    "fs:allow-rename",
    "fs:allow-remove",
    "fs:allow-watch",
    {
      "identifier": "fs:scope",
      "allow": ["$HOME/**", "$APPCACHE/**"],
      "deny": [
        "$HOME/.ssh/**",
        "$HOME/.gnupg/**",
        "$HOME/.aws/**",
        "$HOME/.azure/**",
        "$HOME/.config/gcloud/**",
        "$HOME/.docker/**",
        "$HOME/.kube/**",
        "$HOME/.git-credentials",
        "$HOME/AppData/Roaming/Microsoft/Credentials/**",
        "$HOME/AppData/Roaming/Microsoft/Crypto/**",
        "$HOME/AppData/Roaming/GnuPG/**"
      ]
    },
    {
      "identifier": "core:app:allow-app-show",
      "allow": []
    }
  ]
}
