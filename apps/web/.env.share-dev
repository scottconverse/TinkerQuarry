# Local share testing only (`pnpm share:dev` -> ./dist-share-dev).
#
# WEB-6: this output directory is deliberately NOT ./dist. ./dist is
# wrangler.toml's `pages_build_output_dir`, and a localhost-pinned bundle must
# never be able to land there.
VITE_SHARE_ENABLED=true
VITE_SHARE_API_URL=http://localhost:8788
